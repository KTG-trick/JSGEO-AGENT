# OpenAI dispatcher
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_BASE_URL=https://xint.cc
OPENAI_REASONING_EFFORT=medium

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_DEEP_THINKING=true
DEEPSEEK_REASONING_EFFORT=high

# Doubao / Volcengine Ark
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-2-0-lite-260428
DOUBAO_REASONING_EFFORT=high
DOUBAO_ASSISTANT_MODEL=

# Knowledge extraction model.
# Current policy always uses OpenAI/GPT for higher-quality enterprise fact extraction.
GEO_EXTRACTION_PROVIDER=openai
GEO_EXTRACTION_MODEL=gpt-5.4
# xint.cc uses OpenAI Responses for this model in the current setup.
GEO_EXTRACTION_API_FAMILY=responses
# Keep this empty unless your OpenAI-compatible model supports json_object.
GEO_EXTRACTION_RESPONSE_FORMAT=

# Task models. UI uses Auto; the app chooses model/network mode by task.
GEO_GENERATION_MODEL=
GEO_GENERATION_DOUBAO_MODEL=doubao-seed-2-0-lite-260428
GEO_GENERATION_DEEPSEEK_MODEL=deepseek-v4-pro
GEO_REFLECTION_PROVIDER=openai
GEO_REFLECTION_MODEL=gpt-5.4

# Ark embedding for local sqlite-vec knowledge retrieval.
ARK_EMBEDDING_MODEL=doubao-embedding-vision-251215
ARK_EMBEDDING_DIMENSIONS=1024
ARK_EMBEDDING_CONCURRENCY=2
ARK_EMBEDDING_MAX_RETRIES=2

# Chaojimeijie publishing adapter.
CHAOJIMEIJIE_APPID=01KSHY9MG6DKG0RC17QFZ7NN8J
CHAOJIMEIJIE_SECRET=OTgv5EXvGh6rQ423F7saWliB7ih7esSD
CHAOJIMEIJIE_API_BASE_URL=https://vip.chaojimeijie.com/api

# Aliyun OSS article preview hosting.
ALI_OSS_REGION=
ALI_OSS_BUCKET=
ALI_OSS_ACCESS_KEY_ID=
ALI_OSS_ACCESS_KEY_SECRET=
ALI_OSS_PUBLIC_BASE_URL=
